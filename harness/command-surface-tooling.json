{
	"commands": [
		{
			"id": "root.build",
			"display": "bun run build",
			"requires": ["bun_install"],
			"summary": "Build all workspaces through Turbo."
		},
		{
			"id": "root.dev",
			"display": "bun run dev",
			"requires": ["bun_install"],
			"summary": "Start all workspace dev processes in parallel."
		},
		{
			"id": "root.lint",
			"display": "bun run lint",
			"requires": ["bun_install"],
			"summary": "Run the root Biome checks and workspace lint scripts."
		},
		{
			"id": "root.lint-root",
			"display": "bun run lint:root",
			"requires": ["bun_install"],
			"summary": "Run repository-wide Biome checks from the root."
		},
		{
			"id": "root.lint-biome",
			"display": "bun run lint:biome",
			"requires": ["bun_install"],
			"summary": "Run repository-wide Biome lint rules only."
		},
		{
			"id": "root.typecheck",
			"display": "bun run typecheck",
			"requires": ["bun_install"],
			"summary": "Run root and workspace type checks."
		},
		{
			"id": "root.typecheck-root",
			"display": "bun run typecheck:root",
			"requires": ["bun_install"],
			"summary": "Run the root TypeScript type check."
		},
		{
			"id": "root.test",
			"display": "bun run test",
			"requires": ["bun_install"],
			"summary": "Run all workspace tests through Turbo."
		},
		{
			"id": "root.check",
			"display": "bun run check",
			"requires": ["bun_install"],
			"summary": "Run the full Biome check against the repository."
		},
		{
			"id": "root.format",
			"display": "bun run format",
			"requires": ["bun_install"],
			"summary": "Rewrite files into the repository's canonical format."
		},
		{
			"id": "root.format-check",
			"display": "bun run format:check",
			"requires": ["bun_install"],
			"summary": "Verify that repository files already match the canonical format."
		}
	]
}
