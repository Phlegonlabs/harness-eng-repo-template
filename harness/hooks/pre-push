#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
echo "harness: running pre-push structural tests..."
echo ""

if bun run harness:structural; then
  echo ""
  echo "harness: pre-push checks passed."
else
  echo ""
  echo "harness: pre-push checks FAILED."
  exit 1
fi
