# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# Project identity (set by bun run harness:bootstrap -- <name>)
PROJECT_NAME=harness-template

# Harness level (1=individual, 2=team, 3=org)
HARNESS_LEVEL=2

# Add your project-specific environment variables below:
# DATABASE_URL=
# API_KEY=
