{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": [
			"Read(**)",
			"Write(src/**)",
			"Write(tests/**)",
			"Write(docs/**)",
			"Write(skills/**)",
			"Bash(git *)",
			"Bash(grep *)",
			"Bash(find *)",
			"Bash(cat *)",
			"Bash(chmod +x *)",
			"Bash(bun run harness:*)",
			"Bash(./evals/*)"
		],
		"deny": [
			"Bash(rm -rf /)",
			"Bash(rm -rf ~)",
			"Bash(git push --force *)",
			"Bash(git reset --hard *)",
			"Bash(curl * | bash)",
			"Bash(wget * | bash)",
			"Bash(chmod -R 777 *)"
		]
	},
	"hooks": {
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash hooks/pre-stop.sh",
						"timeout": 120
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash hooks/post-stop-notify.sh",
						"timeout": 30
					}
				]
			}
		]
	},
	"model": "opus"
}
